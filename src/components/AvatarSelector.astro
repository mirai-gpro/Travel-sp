---
// AvatarSelector.astro - アバター切り替えモーダル
---

<!-- アバター切り替えボタン -->
<button class="btn-floating btn-avatar-switch" id="avatarSwitchBtn" title="アバター切替">
  👤
</button>

<!-- モーダル -->
<div class="avatar-modal-overlay hidden" id="avatarModalOverlay">
  <div class="avatar-modal">
    <div class="avatar-modal-header">
      <h3>アバター選択</h3>
      <button class="avatar-modal-close" id="avatarModalClose">&times;</button>
    </div>
    <div class="avatar-modal-body" id="avatarModalBody">
      <!-- JS で動的に生成 -->
    </div>
  </div>
</div>

<style>
.btn-avatar-switch {
  position: fixed;
  top: 12px;
  right: 12px;
  z-index: 100;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.3);
  background: rgba(0,0,0,0.5);
  color: white;
  font-size: 20px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-avatar-switch:hover {
  background: rgba(0,0,0,0.7);
}

.avatar-modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-modal-overlay.hidden {
  display: none;
}

.avatar-modal {
  background: white;
  border-radius: 16px;
  padding: 20px;
  max-width: 400px;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
}

.avatar-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.avatar-modal-header h3 {
  margin: 0;
  font-size: 18px;
}
.avatar-modal-close {
  background: none;
  border: none;
  font-size: 24px;
  cursor: pointer;
  padding: 0 4px;
}

.avatar-modal-body {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
  gap: 12px;
}
</style>

<!-- 動的生成される要素用のグローバルスタイル
     <script> 内で document.createElement で作られる要素には Astro の scoped style が
     当たらないため、別ブロックで is:global として定義する。 -->
<style is:global>
.avatar-modal-body .avatar-option {
  border: 2px solid #ddd;
  border-radius: 12px;
  padding: 8px;
  cursor: pointer;
  text-align: center;
  transition: border-color 0.2s, transform 0.2s;
}
.avatar-modal-body .avatar-option:hover {
  border-color: #666;
  transform: scale(1.05);
}
.avatar-modal-body .avatar-option.selected {
  border-color: #4A90D9;
  background: #EBF5FF;
}
.avatar-modal-body .avatar-option img {
  width: 80px;
  height: 80px;
  object-fit: cover;
  border-radius: 8px;
  display: block;
  margin: 0 auto;
}
.avatar-modal-body .avatar-option .avatar-name {
  font-size: 12px;
  margin-top: 4px;
  color: #333;
}
.avatar-modal-body .avatar-option .avatar-id {
  font-size: 11px;
  color: #888;
}
</style>

<script>
  import { loadAvatarConfig, getSelectedAvatarId, setSelectedAvatar, type AvatarDef } from '../config/avatar-config';

  const btn = document.getElementById('avatarSwitchBtn');
  const overlay = document.getElementById('avatarModalOverlay');
  const closeBtn = document.getElementById('avatarModalClose');
  const body = document.getElementById('avatarModalBody');

  const mode = window.location.pathname.includes('concierge') ? 'concierge' : 'lesson';

  btn?.addEventListener('click', async () => {
    const avatars = await loadAvatarConfig();
    const currentId = getSelectedAvatarId(mode);
    renderAvatars(avatars, currentId);
    overlay?.classList.remove('hidden');
  });

  closeBtn?.addEventListener('click', () => {
    overlay?.classList.add('hidden');
  });

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) overlay.classList.add('hidden');
  });

  function renderAvatars(avatars: AvatarDef[], currentId: string) {
    if (!body) return;
    body.innerHTML = '';

    avatars.forEach(avatar => {
      const div = document.createElement('div');
      div.className = `avatar-option${avatar.id === currentId ? ' selected' : ''}`;

      // サムネがあればサムネ、なければファイル名
      const hasThumb = avatar.thumbnail;
      if (hasThumb) {
        const img = document.createElement('img');
        img.src = avatar.thumbnail!;
        img.alt = avatar.name;
        img.onerror = () => {
          // サムネ読み込み失敗時はファイル名表示に切替
          img.style.display = 'none';
          const nameEl = div.querySelector('.avatar-name');
          if (nameEl) nameEl.textContent = `${avatar.name} (${avatar.id})`;
        };
        div.appendChild(img);
      }

      const nameEl = document.createElement('div');
      nameEl.className = 'avatar-name';
      nameEl.textContent = avatar.name;
      div.appendChild(nameEl);

      if (!hasThumb) {
        const idEl = document.createElement('div');
        idEl.className = 'avatar-id';
        idEl.textContent = avatar.id;
        div.appendChild(idEl);
      }

      div.addEventListener('click', () => {
        if (avatar.id === currentId) {
          overlay?.classList.add('hidden');
          return;
        }
        setSelectedAvatar(mode, avatar);
        // セッションリロード
        window.location.reload();
      });

      body.appendChild(div);
    });
  }
</script>
